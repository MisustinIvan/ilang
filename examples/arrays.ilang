extrn unit printf(string format, ...)

unit print_array([n]int array, string name) {
	let idx: int = 0;
	printf("len: %d\n", n);
	for idx < n {
		printf("%s[%d] = %d\n", name, idx, array[idx]);
		idx = idx + 1;
	};
}

int main() {

	let x: [3]int = [1,2,3];
	let y: [3]int = [4,5,6];
	print_array(x, "x");
	print_array(y, "y");
	x=y;
	printf("\nx = y\n\n");
	print_array(x, "x");
	print_array(y, "y");
	0
}
